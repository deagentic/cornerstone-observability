# Copy this file to .env and fill in the values before running docker-compose.
# DO NOT commit .env to version control.
#
# SECURITY (ADR-0007, F1): POSTGRES_PASSWORD must be set — docker-compose will
# refuse to start if it is absent. Use a strong random password in production.

POSTGRES_DB=agentic_telemetry
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=change_me_in_production

# HTTP Basic Auth for dashboard and query API (ADR-0007, F7).
# Leave both empty to disable auth (local development only).
# Set strong credentials for any network-exposed deployment.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_in_production
